# =============================================================================
# Configuration globale — AdmHost SaaS
# =============================================================================

APP_NAME="AdmHost SaaS"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Chiffrement (générer : php -r "echo bin2hex(random_bytes(32));")
APP_ENCRYPTION_KEY=

# Base de données — NE PAS utiliser root en production
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=admhost
DB_USER=admhost_user
DB_PASS=admhost_local_dev
# Alias supporté : DB_PASSWORD=admhost_local_dev

# API Backend (serveur PHP built-in local)
API_URL=http://localhost:8001

# Sessions (24h)
SESSION_LIFETIME=86400

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_ALLOWED_IPS=

# Rate limiting login
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=900
LOGIN_LOCKOUT_SECONDS=1800

# Stripe (optionnel en local)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# Provisionnement
SSH_HOST=srv.admhost.local
SMTP_HOST=mail.admhost.local
PROVISION_USER=provisioner
