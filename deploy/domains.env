# =============================================================================
# AdmHost — Domaines production (VPS Scaleway — tout sur un serveur)
# Usage : source deploy/domains.env
# =============================================================================

# --- Architecture : VPS unique (recommandé) ---
DEPLOY_TARGET=vps
VPS_IP=51.159.66.221

# --- Domaines (DNS A → VPS_IP depuis O2Switch) ---
VITRINE_URL=https://admhost.fr
CONSOLE_URL=https://console.admhost.fr
ADMIN_URL=https://manage.console.admhost.fr
API_URL=https://api.admhost.fr
API_DOMAIN=api.admhost.fr

VITRINE_DOMAIN=admhost.fr
CONSOLE_DOMAIN=console.admhost.fr
ADMIN_DOMAIN=manage.console.admhost.fr

# --- Git ---
GIT_REPO=https://github.com/admhostgtu/admhost.git
GIT_BRANCH=main

# --- CORS API ---
CORS_ALLOWED_ORIGINS=https://admhost.fr,https://console.admhost.fr,https://manage.console.admhost.fr

# --- Admin : OBLIGATOIRE en production ---
# ADMIN_ALLOWED_IPS=203.0.113.1

# --- Scaleway SSH ---
# VPS_USER=gtusuperuser
# VPS_HOST=51.159.66.221
