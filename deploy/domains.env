# =============================================================================
# AdmHost — Domaines production (sourcé par les scripts deploy)
# Usage : source deploy/domains.env
# =============================================================================

# --- Domaines publics ---
VITRINE_URL=https://admhost.fr
CONSOLE_URL=https://console.admhost.fr
ADMIN_URL=https://manage.console.admhost.fr
API_URL=https://api.admhost.fr
API_DOMAIN=api.admhost.fr

# --- Git ---
GIT_REPO=https://github.com/admhostgtu/admhost.git
GIT_BRANCH=main

# --- CORS API (origines autorisées, séparées par virgule) ---
CORS_ALLOWED_ORIGINS=https://admhost.fr,https://console.admhost.fr,https://manage.console.admhost.fr

# --- Chemins web O2Switch (surcharger si structure différente) ---
# VITRINE_WEB=$HOME/admhost.fr/public_html
# CONSOLE_WEB=$HOME/console.admhost.fr/public_html
# ADMIN_WEB=$HOME/manage.console.admhost.fr/public_html

# --- O2Switch SSH (deploy distant depuis PC) ---
# O2SWITCH_USER=votre_login
# O2SWITCH_HOST=ssh.o2switch.net

# --- Admin : OBLIGATOIRE en production (votre IP publique) ---
# ADMIN_ALLOWED_IPS=203.0.113.1

# --- Scaleway VPS (deploy-all depuis PC) ---
# SCW_HOST=root@IP_VPS
