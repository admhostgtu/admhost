# Apache — frontend/public (local dev / fallback)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>

<Files ".env">
    Require all denied
</Files>

<FilesMatch "\.(env|log|sql|sh|md|gitignore)$">
    Require all denied
</FilesMatch>

RedirectMatch 403 ^/(shared|storage|scripts|backend|admin|admhost)/

Options -Indexes
