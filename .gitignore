# Environnement (secrets — ne jamais versionner)
.env
.env.local
.env.production

# Garder les templates versionnés
!.env.example
!deploy/env.production

# Storage (logs, cache, backups)
storage/logs/*
storage/cache/*
storage/backups/*
!storage/logs/.gitkeep
!storage/cache/.gitkeep
!storage/backups/.gitkeep

